# Swarm Subnet V4 Configuration
# Copy this file to .env and set your values

# =============================================================================
# REQUIRED FOR VALIDATORS
# =============================================================================

# Backend API URL (validators only — miners submit via chain, no URL needed)
SWARM_BACKEND_API_URL=URL_HERE

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Wandb API Key for logging (distributed separately to validators)
WANDB_API_KEY=your_wandb_api_key_here

# Custom validator name (defaults to validator-{uid})
VALIDATOR_NAME=validator-name

# Wandb Project settings (already configured in code)
# PROJECT: validator-logs
# ENTITY: swarm-subnet-swarm
# URL: https://wandb.ai/swarm-subnet-swarm/validator-logs

include LICENSE
include README.md
include docs/CLI_readme.md
prune tests
recursive-include swarm/assets *
recursive-include swarm/submission_template *
recursive-include swarm/templates *
recursive-include swarm/validator/docker *
recursive-exclude swarm/assets/open_terrain *
recursive-exclude swarm/assets/maps/forest/terrain_cache *
prune swarm/assets/map_images
